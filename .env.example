# ---------------------------------------------------------------------------
# Firebase Web SDK config (CLIENT-SIDE — safe to expose; these are NOT secrets).
# Copy this file to ".env" and fill in values from:
#   Firebase Console > Project settings > Your apps > SDK setup and configuration
# Vite only exposes variables prefixed with VITE_ to the browser.
# ---------------------------------------------------------------------------
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# Optional: Firebase Cloud Messaging Web Push (VAPID) public key for notifications.
VITE_FIREBASE_VAPID_KEY=

# Point the app at local emulators during development ("true" / "false").
VITE_USE_EMULATORS=false

# ---------------------------------------------------------------------------
# NOTE: AI provider API keys are NEVER configured here. Each user supplies their
# own key in the in-app AI Settings panel; keys are stored in browser
# localStorage only and never written to Firestore. See src/services/ai/.
# ---------------------------------------------------------------------------
