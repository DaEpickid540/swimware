rules_version = '2';

// =============================================================================
// Firebase Storage rules (no Cloud Functions). Roles are read cross-service
// from Firestore users/{uid}.role via firestore.get() — the same doc-based
// model the Firestore rules use, so everything stays on the Spark plan.
// =============================================================================

service firebase.storage {
  match /b/{bucket}/o {

    function signedIn() {
      return request.auth != null;
    }
    function userRole() {
      return signedIn()
        ? firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role
        : '';
    }
    function isStaff() {
      return userRole() == 'admin' || userRole() == 'coach';
    }
    function inTeam(teamId) {
      return signedIn()
        && teamId in firestore.get(/databases/(default)/documents/users/$(request.auth.uid))
             .data.get('assignedTeams', []);
    }

    // Team documents — members read, staff write (≤25 MB).
    match /team-docs/{teamId}/{fileName} {
      allow read: if isStaff() || inTeam(teamId);
      allow write: if isStaff() && request.resource.size < 25 * 1024 * 1024;
    }

    // Branding / logos — any signed-in user reads; admins write images (≤5 MB).
    match /branding/{fileName} {
      allow read: if signedIn();
      allow write: if userRole() == 'admin'
        && request.resource.contentType.matches('image/.*')
        && request.resource.size < 5 * 1024 * 1024;
    }

    // A user's own uploads (avatar, etc.) (≤10 MB).
    match /user-uploads/{uid}/{fileName} {
      allow read: if signedIn() && (request.auth.uid == uid || isStaff());
      allow write: if signedIn() && request.auth.uid == uid
        && request.resource.size < 10 * 1024 * 1024;
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
