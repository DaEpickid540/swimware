{
  "name": "swimware",
  "version": "0.1.0",
  "private": true,
  "description": "Mason Rec Rays — secure swim team program (admins, coaches, swimmers)",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "icons": "node scripts/generate-icons.mjs",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "emulators": "firebase emulators:start",
    "deploy": "npm run build && firebase deploy --only hosting,firestore,storage",
    "deploy:hosting": "npm run build && firebase deploy --only hosting",
    "deploy:rules": "firebase deploy --only firestore:rules,storage",
    "functions:build": "npm --prefix functions run build",
    "functions:deploy": "firebase deploy --only functions"
  },
  "dependencies": {
    "firebase": "^11.0.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.2"
  },
  "devDependencies": {
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.2",
    "sharp": "^0.35.1",
    "typescript": "^5.6.2",
    "vite": "^5.4.8",
    "vite-plugin-pwa": "^1.3.0"
  }
}
