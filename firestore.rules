rules_version = '2';

// =============================================================================
// Mason Rec Rays — Firestore Security Rules  (NO Cloud Functions / Spark plan)
// -----------------------------------------------------------------------------
// Roles live in the user's own document: users/{uid}.role ∈ admin|coach|swimmer.
// Rules read it with get(); there are no custom claims, so the whole app runs
// on the free Spark plan. Trust is anchored two ways:
//   * ADMIN: a user may set their OWN role to 'admin' only if their email is in
//     the hard-coded ADMIN_EMAILS list below (so admin can't be forged).
//   * SWIMMER: a swimmer doc can only be created in the same breath as redeeming
//     a valid, unused, unexpired invite token (cross-doc get() check). Replays
//     fail because the token flips to used=true.
//   * COACH: granted by an admin (pendingUsers pre-registration or a direct
//     role edit). Coaches cannot self-promote.
// Team membership is users/{uid}.assignedTeams[] (an array of team IDs).
// =============================================================================

service cloud.firestore {
  match /databases/{database}/documents {

    // ---- Hard-coded admin allow-list (Gmail dot-variants included) ----------
    function adminEmails() {
      return [
        'sarvin.sukhe@gmail.com',
        'sarvinsukhe@gmail.com',
        'daepickid540@gmail.com'
      ];
    }
    function callerEmail() {
      return request.auth != null ? request.auth.token.email.lower() : '';
    }
    function isAdminEmail() {
      return callerEmail() in adminEmails();
    }

    // ---- Identity / role helpers (role read from the user's own doc) --------
    function isSignedIn() {
      return request.auth != null;
    }
    function uid() {
      return request.auth.uid;
    }
    function isSelf(userId) {
      return isSignedIn() && uid() == userId;
    }
    function userDoc() {
      return get(/databases/$(database)/documents/users/$(uid())).data;
    }
    function role() {
      return isSignedIn() ? userDoc().role : '';
    }
    function isAdmin() {
      return isSignedIn() && role() == 'admin';
    }
    function isCoach() {
      return isSignedIn() && role() == 'coach';
    }
    function isStaff() {
      return isAdmin() || isCoach();
    }
    function notBanned() {
      return isSignedIn() && userDoc().get('active', true) == true;
    }
    // Team membership from the caller's own assignedTeams array.
    function inTeam(teamId) {
      return isSignedIn() && teamId in userDoc().get('assignedTeams', []);
    }
    function coachesTeam(teamId) {
      return isAdmin() || (isCoach() && inTeam(teamId));
    }
    function unchanged(field) {
      return !(field in request.resource.data)
        || request.resource.data[field] == resource.data[field];
    }

    // ---------------------------------------------------------------------
    // users — the role/profile document (also the trust anchor)
    // ---------------------------------------------------------------------
    match /users/{userId} {
      // Minors' PII (age, parent/emergency contacts, medical notes) is tightly
      // scoped: admins see all; a user sees themselves; a COACH may read a user
      // ONLY if they share at least one team. A coach can never read swimmers
      // (or staff) outside their own teams. (Ohio youth-data minimization.)
      allow read: if isAdmin()
        || isSelf(userId)
        || (isCoach()
            && resource.data.get('assignedTeams', []).hasAny(userDoc().get('assignedTeams', [])));

      // CREATE — three legitimate provisioning paths, all writing your OWN doc:
      allow create: if isSelf(userId) && (
        // (a) Admin bootstrap: email is in the allow-list.
        (request.resource.data.role == 'admin' && isAdminEmail()) ||
        // (b) Coach pre-registered by an admin in pendingUsers.
        (request.resource.data.role == 'coach' && pendingRoleIs('coach')) ||
        // (c) Swimmer redeeming a valid invite token (see validInvite()).
        (request.resource.data.role == 'swimmer' &&
         request.resource.data.assignedTeams is list &&
         request.resource.data.assignedTeams.size() == 1 &&
         validInvite(request.resource.data.get('invitedVia', ''),
                     request.resource.data.assignedTeams[0]))
      );

      // UPDATE — admin can edit anyone; admin-email holder may self-promote to
      // admin; otherwise you may edit only safe fields of your own doc.
      allow update: if isAdmin()
        || (isSelf(userId) && isAdminEmail() && request.resource.data.role == 'admin')
        || (isSelf(userId)
            && unchanged('role')
            && unchanged('email')
            && unchanged('assignedTeams')
            && unchanged('active')
            && unchanged('consents'));

      allow delete: if isAdmin();
    }

    // Reads the committed invite token and verifies it is currently redeemable
    // for this team. Because rules see COMMITTED state, a second redemption of
    // the same token (now used=true) fails — enforcing single use across the
    // two writes of the claim batch.
    function validInvite(token, teamId) {
      return token != ''
        && exists(/databases/$(database)/documents/inviteTokens/$(token))
        && inviteData(token).used == false
        && inviteData(token).get('revoked', false) == false
        && inviteData(token).expiresAt > request.time.toMillis()
        && inviteData(token).teamId == teamId;
    }
    function inviteData(token) {
      return get(/databases/$(database)/documents/inviteTokens/$(token)).data;
    }
    // Deterministic pendingUsers doc id: lowercase email with '.' -> '_'
    // (e.g. "a.b@gmail.com" -> "a_b@gmail_com"). Must match the client.
    function emailKey() {
      return callerEmail().replace('\\.', '_');
    }
    // True if an admin pre-registered this caller's email with the given role.
    function pendingRoleIs(r) {
      return exists(/databases/$(database)/documents/pendingUsers/$(emailKey()))
        && get(/databases/$(database)/documents/pendingUsers/$(emailKey())).data.role == r;
    }

    // ---------------------------------------------------------------------
    // pendingUsers/{emailKey} — admin pre-assigns a coach role before signup.
    // On first sign-in the matching user reads their record and provisions.
    // ---------------------------------------------------------------------
    match /pendingUsers/{emailKey} {
      allow get: if isSignedIn();           // claim lookup by deterministic id
      allow list: if isAdmin();
      allow create, update: if isAdmin();
      allow delete: if isAdmin()
        || (isSignedIn() && resource.data.email.lower() == callerEmail());
    }

    // ---------------------------------------------------------------------
    // accessRequests/{uid} — a signed-in user asks to become a coach; admin
    // approves by writing pendingUsers / editing their users role.
    // ---------------------------------------------------------------------
    match /accessRequests/{reqId} {
      allow read: if isAdmin() || isSelf(reqId);
      allow create: if isSelf(reqId)
        && request.resource.data.status == 'pending'
        && request.resource.data.keys().hasAll(['email', 'requestedAt', 'status']);
      allow update: if isAdmin()
        || (isSelf(reqId) && request.resource.data.status == 'pending');
      allow delete: if isAdmin() || isSelf(reqId);
    }

    // ---------------------------------------------------------------------
    // teams
    // ---------------------------------------------------------------------
    match /teams/{teamId} {
      allow read: if isStaff() || inTeam(teamId);
      allow create: if isStaff();
      allow update: if coachesTeam(teamId)
        // Anyone redeeming an invite may add only THEIR OWN uid to swimmers[].
        || (isSignedIn()
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['swimmers'])
            && request.resource.data.swimmers.removeAll(resource.data.swimmers) == [uid()]);
      allow delete: if coachesTeam(teamId);
    }

    // ---------------------------------------------------------------------
    // events
    // ---------------------------------------------------------------------
    match /events/{eventId} {
      allow read: if isStaff() || inTeam(resource.data.teamId);
      allow create: if isStaff() && coachesTeam(request.resource.data.teamId);
      allow update, delete: if coachesTeam(resource.data.teamId);
    }

    // ---------------------------------------------------------------------
    // signups (RSVPs)
    // ---------------------------------------------------------------------
    match /signups/{signupId} {
      // Coaches read RSVPs only for their own teams; swimmers read their own.
      allow read: if isAdmin()
        || isSelf(resource.data.swimmerId)
        || (isCoach() && inTeam(resource.data.teamId));
      allow create: if isSelf(request.resource.data.swimmerId)
        && notBanned()
        && inTeam(request.resource.data.teamId);
      allow update, delete: if isAdmin()
        || isSelf(resource.data.swimmerId)
        || (isCoach() && inTeam(resource.data.teamId));
    }

    // ---------------------------------------------------------------------
    // inviteTokens — created by staff; redeemed by flipping used:false->true.
    // ---------------------------------------------------------------------
    match /inviteTokens/{tokenId} {
      allow get: if true;                    // claim page reads token by id
      allow list: if isStaff();
      allow create: if isStaff() && coachesTeam(request.resource.data.teamId)
        && request.resource.data.used == false;
      // Redeem: any signed-in user may flip an unused, unexpired, unrevoked
      // token to used=true and stamp who claimed it. Nothing else may change.
      allow update: if isAdmin()
        || (isSignedIn()
            && resource.data.used == false
            && resource.data.get('revoked', false) == false
            && resource.data.expiresAt > request.time.toMillis()
            && request.resource.data.used == true
            && request.resource.data.diff(resource.data).affectedKeys()
                 .hasOnly(['used', 'usedBy', 'usedAt']));
      allow delete: if isAdmin();
    }

    // ---------------------------------------------------------------------
    // chats + messages
    // -----------------------------------------------------------------------
    // YOUTH-SAFETY: the ONLY chat that can exist is one canonical GROUP chat
    // per team (chat doc id == teamId, type == 'team_chat'). There is no path
    // to create a 1:1 / private chat, so an adult can never open a private
    // channel with a minor. Every message is visible to the whole team and to
    // coaches/admins (moderation), satisfying the "group-based, monitored,
    // parent-reviewable" requirement. Ohio Rev. Code §2907-aligned design.
    // ---------------------------------------------------------------------
    match /chats/{chatId} {
      allow read: if isStaff() || inTeam(resource.data.teamId);
      // Canonical team group chat only: id must equal the teamId, type fixed,
      // and the creator must coach that team.
      allow create: if isStaff()
        && request.resource.data.type == 'team_chat'
        && chatId == request.resource.data.teamId
        && coachesTeam(request.resource.data.teamId);
      // Only coaches/admins may adjust moderation (mutedUsers); no type change.
      allow update: if coachesTeam(resource.data.teamId)
        && request.resource.data.type == resource.data.type
        && request.resource.data.teamId == resource.data.teamId;
      allow delete: if coachesTeam(resource.data.teamId);

      match /messages/{messageId} {
        allow read: if isStaff()
          || inTeam(get(/databases/$(database)/documents/chats/$(chatId)).data.teamId);
        allow create: if isSignedIn()
          && notBanned()
          && request.resource.data.senderId == uid()
          && (isStaff()
              || inTeam(get(/databases/$(database)/documents/chats/$(chatId)).data.teamId))
          && !(uid() in
               get(/databases/$(database)/documents/chats/$(chatId)).data.get('mutedUsers', []));
        // Authors may edit/delete their own message; staff moderate any.
        // (No hard delete of others' content beyond moderation = retained trail.)
        allow update, delete: if isSelf(resource.data.senderId) || isStaff();
      }
    }

    // ---------------------------------------------------------------------
    // news / announcements
    // ---------------------------------------------------------------------
    match /news/{newsId} {
      allow read: if isStaff()
        || 'all' in resource.data.visibleTo
        || role() in resource.data.visibleTo
        || resource.data.visibleTo.hasAny(userDoc().get('assignedTeams', []));
      allow create, update, delete: if isStaff();
    }

    // ---------------------------------------------------------------------
    // aiSettings — per-user, non-secret prefs only (keys stay in localStorage)
    // ---------------------------------------------------------------------
    match /aiSettings/{userId} {
      allow read, write: if isSelf(userId);
    }

    // ---------------------------------------------------------------------
    // performanceLogs / attendance — coaches write, swimmers read their own
    // ---------------------------------------------------------------------
    match /performanceLogs/{logId} {
      allow read: if isStaff() || isSelf(resource.data.swimmerId);
      allow create, update, delete: if isStaff();
    }
    match /attendance/{attId} {
      // Coaches read attendance only for their own teams; swimmers read theirs.
      allow read: if isAdmin()
        || isSelf(resource.data.swimmerId)
        || (isCoach() && inTeam(resource.data.teamId));
      allow create, update, delete: if isAdmin()
        || (isCoach() && inTeam(request.resource.data.get('teamId', resource.data.teamId)));
    }

    // ---------------------------------------------------------------------
    // timeStandards & goals
    // ---------------------------------------------------------------------
    match /timeStandards/{stdId} {
      allow read: if isSignedIn();
      allow write: if isStaff();
    }
    match /goals/{goalId} {
      allow read: if isStaff() || isSelf(resource.data.swimmerId);
      allow create: if isStaff() || isSelf(request.resource.data.swimmerId);
      allow update, delete: if isStaff() || isSelf(resource.data.swimmerId);
    }

    // ---------------------------------------------------------------------
    // documents (Storage metadata)
    // ---------------------------------------------------------------------
    match /documents/{docId} {
      allow read: if isStaff() || inTeam(resource.data.teamId);
      allow create: if isStaff() && coachesTeam(request.resource.data.teamId);
      allow update, delete: if coachesTeam(resource.data.teamId);
    }

    // ---------------------------------------------------------------------
    // notifications — per-user inbox. Owner reads + marks read; staff may
    // create notifications for others (e.g. RSVP/announcement pings).
    // ---------------------------------------------------------------------
    match /notifications/{notifId} {
      allow read: if isSelf(resource.data.userId);
      allow update: if isSelf(resource.data.userId)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
      allow delete: if isSelf(resource.data.userId);
      allow create: if isStaff() || isSelf(request.resource.data.userId);
    }

    // ---------------------------------------------------------------------
    // settings — global app/team config
    // ---------------------------------------------------------------------
    match /settings/{settingId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // ---------------------------------------------------------------------
    // auditLogs — append-only client trail (admin-readable). Anyone signed in
    // may append an entry about THEIR OWN action; nobody may edit/delete.
    // ---------------------------------------------------------------------
    match /auditLogs/{logId} {
      allow read: if isAdmin();
      allow create: if isSignedIn() && request.resource.data.actorId == uid();
      allow update, delete: if false;
    }

    // ---------------------------------------------------------------------
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
